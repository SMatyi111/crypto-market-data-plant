{
  "jobs": [
    {
      "name": "binance-btc-depth",
      "job_type": "binance-depth-worker",
      "interval_seconds": 3600,
      "args": {
        "symbol": "btcusdt",
        "speed": "100ms",
        "segment_count": 5000,
        "max_segments": 1,
        "cooldown_seconds": 1.0,
        "connect_retries": 3,
        "retry_backoff_seconds": 2.0,
        "output_root": "D:\\market_archive\\raw\\market",
        "ops_root": "D:\\market_archive\\ops"
      }
    },
    {
      "name": "binance-btc-trades",
      "job_type": "binance-trades-worker",
      "interval_seconds": 3600,
      "args": {
        "symbol": "btcusdt",
        "channel": "trade",
        "segment_count": 5000,
        "max_segments": 1,
        "cooldown_seconds": 1.0,
        "output_root": "D:\\market_archive\\raw\\market",
        "ops_root": "D:\\market_archive\\ops"
      }
    },
    {
      "// per-instrument lanes": "Set source_suffix + a unique worker_name to run a second symbol in its own lane. The legacy single-symbol job above keeps writing to binance_depth/; the new lanes write to binance_depth_ethusdt/, etc., so quarantine/promote can scope per-symbol without interleaving timestamps.",
      "name": "binance-eth-depth",
      "job_type": "binance-depth-worker",
      "enabled": false,
      "interval_seconds": 3600,
      "args": {
        "symbol": "ethusdt",
        "speed": "100ms",
        "segment_count": 5000,
        "max_segments": 1,
        "cooldown_seconds": 1.0,
        "connect_retries": 3,
        "retry_backoff_seconds": 2.0,
        "source_suffix": "ethusdt",
        "worker_name": "binance-depth-worker-ethusdt",
        "output_root": "D:\\market_archive\\raw\\market",
        "ops_root": "D:\\market_archive\\ops"
      }
    },
    {
      "name": "binance-eth-trades",
      "job_type": "binance-trades-worker",
      "enabled": false,
      "interval_seconds": 3600,
      "args": {
        "symbol": "ethusdt",
        "channel": "trade",
        "segment_count": 5000,
        "max_segments": 1,
        "cooldown_seconds": 1.0,
        "source_suffix": "ethusdt",
        "worker_name": "binance-trades-worker-ethusdt",
        "output_root": "D:\\market_archive\\raw\\market",
        "ops_root": "D:\\market_archive\\ops"
      }
    },
    {
      "// multi-venue lane": "Coinbase trades use the same generic WS collector + trades curation chain as Binance; only the endpoint, subscription style and normalizer differ. Runs land in coinbase_trades/ so the quarantine/promote-coinbase-trades jobs below can curate them independently. Set source_suffix for a second Coinbase product (e.g. ETH-USD).",
      "name": "coinbase-btc-trades",
      "job_type": "coinbase-trades-worker",
      "enabled": false,
      "interval_seconds": 3600,
      "args": {
        "symbol": "BTC-USD",
        "channel": "matches",
        "segment_count": 5000,
        "max_segments": 1,
        "cooldown_seconds": 1.0,
        "worker_name": "coinbase-trades-worker",
        "output_root": "D:\\market_archive\\raw\\market",
        "ops_root": "D:\\market_archive\\ops"
      }
    },
    {
      "name": "quarantine-coinbase-trades",
      "job_type": "quarantine-runs",
      "enabled": false,
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\coinbase_trades",
        "quarantine_root": "D:\\market_archive\\quarantine\\market\\coinbase_trades",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "promote-coinbase-trades",
      "job_type": "promote-replayable",
      "enabled": false,
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\coinbase_trades",
        "target_root": "D:\\market_archive\\curated\\research\\trades_replayable",
        "quarantine_index": "D:\\market_archive\\quarantine\\market\\coinbase_trades\\_quarantine_index.jsonl",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "book-sync-health",
      "job_type": "book-sync-health",
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\binance_depth",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "quarantine-market",
      "job_type": "quarantine-runs",
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\binance_depth",
        "quarantine_root": "D:\\market_archive\\quarantine\\market\\binance_depth",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "promote-market",
      "job_type": "promote-replayable",
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\binance_depth",
        "target_root": "D:\\market_archive\\curated\\research\\market_replayable",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "quarantine-trades",
      "job_type": "quarantine-runs",
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\binance_trades",
        "quarantine_root": "D:\\market_archive\\quarantine\\market\\binance_trades",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "promote-trades",
      "job_type": "promote-replayable",
      "interval_seconds": 300,
      "args": {
        "source_root": "D:\\market_archive\\raw\\market\\binance_trades",
        "target_root": "D:\\market_archive\\curated\\research\\trades_replayable",
        "quarantine_index": "D:\\market_archive\\quarantine\\market\\binance_trades\\_quarantine_index.jsonl",
        "limit": 20,
        "max_age_hours": 6
      }
    },
    {
      "name": "research-manifest",
      "job_type": "research-manifest",
      "interval_seconds": 900,
      "args": {
        "archive_root": "D:\\market_archive",
        "output_root": "D:\\market_archive\\curated\\research\\manifests"
      }
    },
    {
      "name": "cleanup-dry-run",
      "job_type": "cleanup",
      "interval_seconds": 3600,
      "args": {
        "archive_root": "D:\\market_archive",
        "raw_days": 14,
        "raw_policy": [
          "market/binance_depth=14",
          "market/binance_trades=14"
        ],
        "apply": false
      }
    }
  ]
}
